# Google Maps API Key
# Necesitas habilitar en Google Cloud Console:
#   - Maps JavaScript API
#   - Places API
#   - Directions API
VITE_GOOGLE_MAPS_API_KEY=TU_API_KEY_AQUI

# Google OAuth Client ID
# Obtener en: https://console.cloud.google.com/apis/credentials
# Asegúrate de agregar http://localhost:5173 a "Authorized JavaScript origins"
VITE_GOOGLE_CLIENT_ID=
